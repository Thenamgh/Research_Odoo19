<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ================ THESIS TOPIC VIEWS ================ -->

        <!-- Tree View -->
        <record id="thesis_topic_tree" model="ir.ui.view">
            <field name="name">thesis.topic.tree</field>
            <field name="model">thesis.topic</field>
            <field name="arch" type="xml">
                <list string="Danh Sách Đề Tài">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="advisor_id"/>
                    <field name="max_students"/>
                    <field name="assigned_count"/>
                    <field name="available_slots"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="thesis_topic_form" model="ir.ui.view">
            <field name="name">thesis.topic.form</field>
            <field name="model">thesis.topic</field>
            <field name="arch" type="xml">
                <form string="Đề Tài Tốt Nghiệp">
                    <header>
                        <button name="action_close_topic" string="Đóng Đề Tài" type="object" class="btn-danger" invisible="state != 'available'"/>
                        <button name="action_reopen_topic" string="Mở Lại" type="object" class="btn-primary" invisible="state != 'closed'"/>
                        <field name="state" widget="statusbar" options="{'clickable': True}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Tên đề tài"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code" readonly="1"/>
                                <field name="advisor_id" required="1"/>
                                <field name="max_students"/>
                            </group>
                            <group>
                                <field name="assigned_count"/>
                                <field name="available_slots"/>
                                <field name="created_date" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" placeholder="Mô tả chi tiết đề tài"/>
                        </group>
                        <notebook>
                            <page string="Sinh Viên Nhận">
                                <field name="assignment_ids">
                                    <list string="Danh Sách Giao Nhận" editable="bottom">
                                        <field name="student_id"/>
                                        <field name="student_code"/>
                                        <field name="assigned_date"/>
                                        <field name="assigned_by"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="thesis_topic_search" model="ir.ui.view">
            <field name="name">thesis.topic.search</field>
            <field name="model">thesis.topic</field>
            <field name="arch" type="xml">
                <search string="Tìm Đề Tài">
                    <field name="name" string="Tên Đề Tài"/>
                    <field name="code"/>
                    <field name="advisor_id"/>
                    <filter name="available" string="Còn Trống" domain="[('state', '=', 'available')]"/>
                    <filter name="full" string="Đã Đủ" domain="[('state', '=', 'full')]"/>
                    <filter name="closed" string="Đã Đóng" domain="[('state', '=', 'closed')]"/>
                    <separator/>
                    <filter name="group_advisor" string="Giảng viên" context="{'group_by': 'advisor_id'}"/>
                    <filter name="group_state" string="Trạng Thái" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>
        <!-- Action -->
        <record id="thesis_topic_action" model="ir.actions.act_window">
            <field name="name">Quản Lý Đề Tài</field>
            <field name="res_model">thesis.topic</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo đề tài tốt nghiệp mới
                </p>
                <p>
                    Hệ thống giao đề tài cho sinh viên làm đồ án tốt nghiệp
                </p>
            </field>
        </record>

        <!-- ================ THESIS ASSIGNMENT VIEWS ================ -->

        <!-- Assignment Tree View -->
        <record id="thesis_assignment_tree" model="ir.ui.view">
            <field name="name">thesis.assignment.list</field>
            <field name="model">thesis.assignment</field>
            <field name="arch" type="xml">
                <list string="Danh Sách Giao Nhận">
                    <field name="topic_id"/>
                    <field name="student_id"/>
                    <field name="student_code"/>
                    <field name="assigned_date"/>
                    <field name="assigned_by"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Assignment Form View -->
        <record id="thesis_assignment_form" model="ir.ui.view">
            <field name="name">thesis.assignment.form</field>
            <field name="model">thesis.assignment</field>
            <field name="arch" type="xml">
                <form string="Giao Nhận Đề Tài">
                    <header>
                        <button name="action_accept" string="Xác Nhận Nhận" type="object" class="btn-primary" invisible="state != 'assigned'"/>

                        <button name="action_complete" string="Hoàn Thành" type="object" class="btn-success" invisible="state != 'accepted'"/>
                        <button name="action_cancel" string="Hủy" type="object" class="btn-danger" invisible="state not in ['assigned', 'accepted']"/>
                        <field name="state" widget="statusbar" options="{'clickable': True}"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="topic_id" required="1"/>
                                <field name="student_id" required="1"/>
                                <field name="student_code" readonly="1"/>
                            </group>
                            <group>
                                <field name="assigned_date" readonly="1"/>
                                <field name="assigned_by" readonly="1"/>
                            </group>
                        </group>
                        <field name="notes" placeholder="Ghi chú thêm"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Assignment Action -->
        <record id="thesis_assignment_action" model="ir.actions.act_window">
            <field name="name">Danh Sách Giao Nhận</field>
            <field name="res_model">thesis.assignment</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- ================ MENU ================ -->

        <menuitem id="menu_thesis_topic" name="Quản lý Đề tài" parent="menu_thesis_management" action="thesis_topic_action" sequence="20"/>
        <menuitem id="menu_thesis_assignment" name="Giao nhận Đề tài" parent="menu_thesis_management" action="thesis_assignment_action" sequence="30"/>
    </data>
</odoo>
