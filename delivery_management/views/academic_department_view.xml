<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================================================
             LIST VIEW: Danh sách bộ môn
             ================================================== -->
        <record id="academic_department_list" model="ir.ui.view">
            <field name="name">academic.department.list</field>
            <field name="model">academic.department</field>
            <field name="arch" type="xml">
                <list string="Danh sách Bộ môn">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="faculty_id"/>
                    <field name="head_id"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- ==================================================
             FORM VIEW: Thông tin chi tiết bộ môn
             ================================================== -->
        <record id="academic_department_form" model="ir.ui.view">
            <field name="name">academic.department.form</field>
            <field name="model">academic.department</field>
            <field name="arch" type="xml">
                <form string="Bộ môn">
                    <sheet>

                        <!-- Hiển thị tên bộ môn ở đầu biểu mẫu -->
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nhập tên bộ môn..."/>
                            </h1>
                        </div>

                        <group>
                            <!-- Thông tin tổ chức -->
                            <group string="Thông tin chung">
                                <field name="code"/>
                                <field name="faculty_id"/>
                                <field name="head_id"/>
                                <field name="active"/>
                            </group>

                            <!-- Thông tin liên hệ -->
                            <group string="Thông tin liên hệ">
                                <field name="email" widget="email"/>
                                <field name="phone" widget="phone"/>
                                <field name="office"/>
                            </group>
                        </group>

                        <group string="Ghi chú">
                            <field name="note" placeholder="Nhập ghi chú về bộ môn..."/>
                        </group>

                    </sheet>

                    <!-- Theo dõi thay đổi và hoạt động -->
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ==================================================
             SEARCH VIEW: Tìm kiếm bộ môn
             ================================================== -->
        <record id="academic_department_search" model="ir.ui.view">
            <field name="name">academic.department.search</field>
            <field name="model">academic.department</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm Bộ môn">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="faculty_id"/>
                    <field name="head_id"/>

                    <separator/>

                    <filter name="active_department" string="Đang hoạt động" domain="[('active', '=', True)]"/>

                    <filter name="inactive_department" string="Ngừng hoạt động" domain="[('active', '=', False)]"/>

                    <separator/>

                    <!-- Gom nhóm danh sách bộ môn theo khoa -->
                    <filter name="group_by_faculty" string="Nhóm theo Khoa" context="{'group_by': 'faculty_id'}"/>
                </search>
            </field>
        </record>

        <!-- ==================================================
             ACTION: Mở màn hình quản lý bộ môn
             ================================================== -->
        <record id="academic_department_action" model="ir.actions.act_window">
            <field name="name">Danh mục Bộ môn</field>
            <field name="res_model">academic.department</field>
            <field name="view_mode">list,form</field>

            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo bộ môn đầu tiên
                </p>
                <p>
                    Mỗi bộ môn phải trực thuộc một khoa.
                </p>
            </field>
        </record>

        <!-- ==================================================
             MENU: Danh mục Bộ môn
             ================================================== -->
        <menuitem id="menu_academic_department" name="Quản lý Bộ môn" parent="menu_academic_catalog" action="academic_department_action" sequence="10"/>
    </data>
</odoo>