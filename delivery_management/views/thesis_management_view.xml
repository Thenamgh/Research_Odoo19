<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Thesis List -->
        <record id="view_thesis_project_list" model="ir.ui.view">
            <field name="name">thesis.project.list</field>
            <field name="model">thesis.project</field>
            <field name="arch" type="xml">
                <list string="Thesis Projects">
                    <field name="name"/>
                    <field name="title"/>
                    <field name="student_id"/>
                    <field name="supervisor_id"/>
                    <field name="status"/>
                    <field name="grade"/>
                </list>
            </field>
        </record>

        <!-- Thesis Form -->
        <record id="view_thesis_project_form" model="ir.ui.view">
            <field name="name">thesis.project.form</field>
            <field name="model">thesis.project</field>
            <field name="arch" type="xml">
                <form string="Thesis Project">
                    <header>
                        <button name="action_assign" type="object" string="Assign" class="btn-primary"
                                invisible="status != 'draft'"/>
                        <button name="action_start" type="object" string="Start" class="btn-primary"
                                invisible="status != 'assigned'"/>
                        <button name="action_submit" type="object" string="Submit" class="btn-primary"
                                invisible="status != 'in_progress'"/>
                        <button name="action_defend" type="object" string="Defend" class="btn-primary"
                                invisible="status != 'submitted'"/>
                        <button name="action_complete" type="object" string="Complete" class="btn-primary"
                                invisible="status != 'defended'"/>
                        <button name="action_cancel" type="object" string="Cancel"
                                invisible="status in ('cancelled', 'completed')"/>

                        <field name="status" widget="statusbar"/>
                    </header>

                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="code" readonly="1"/>
                                <field name="title"/>
                            </group>

                            <group>
                                <field name="student_id"/>
                                <field name="student_phone" readonly="1"/>
                                <field name="student_email" readonly="1"/>
                            </group>

                            <group>
                                <field name="supervisor_id"/>
                                <field name="assigned_by" readonly="1"/>
                                <field name="created_date" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Timeline">
                                <group>
                                    <field name="start_date"/>
                                    <field name="due_date"/>
                                    <field name="submission_date"/>
                                    <field name="defense_date"/>
                                </group>
                            </page>

                            <page string="Files &amp; Grade">
                                <group>
                                    <field name="attachment" filename="attachment_name"/>
                                    <field name="attachment_name"/>
                                    <field name="grade"/>
                                </group>
                            </page>

                            <page string="Notes">
                                <field name="notes" colspan="4"/>
                            </page>
                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search -->
        <record id="view_thesis_project_search" model="ir.ui.view">
            <field name="name">thesis.project.search</field>
            <field name="model">thesis.project</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="title"/>
                    <field name="student_id"/>
                    <field name="supervisor_id"/>
                    <field name="status"/>

                    <filter string="Draft" name="draft" domain="[('status','=','draft')]"/>
                    <filter string="Assigned" name="assigned" domain="[('status','=','assigned')]"/>
                    <filter string="In Progress" name="in_progress" domain="[('status','=','in_progress')]"/>
                    <filter string="Submitted" name="submitted" domain="[('status','=','submitted')]"/>
                    <filter string="Defended" name="defended" domain="[('status','=','defended')]"/>
                    <filter string="Completed" name="completed" domain="[('status','=','completed')]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_thesis_project" model="ir.actions.act_window">
            <field name="name">Thesis Projects</field>
            <field name="res_model">thesis.project</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_thesis_management" name="Thesis Management" parent="menu_delivery_management" sequence="5"/>
        <menuitem id="menu_thesis_list" name="Projects" parent="menu_thesis_management" action="action_thesis_project" sequence="1"/>

    </data>
</odoo>