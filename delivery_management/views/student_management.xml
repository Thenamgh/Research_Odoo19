<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="thesis_student_list" model="ir.ui.view">
            <field name="name">thesis.student.list</field>
            <field name="model">thesis.student</field>
            <field name="arch" type="xml">
                <list string="Danh Sách Sinh Viên">
                    <field name="student_code"/>
                    <field name="name"/>
                    <field name="class_name"/>
                    <field name="email"/>

                    <field name="state"/>
                    <field name="has_thesis_wish" string = "Có nguyện vọng"/>
                    <field name="eligible_date"/>
                    <field name="wish_date"/>

                    <field name="supervisor_id"/>
                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="thesis_student_form" model="ir.ui.view">
            <field name="name">thesis.student.form</field>
            <field name="model">thesis.student</field>
            <field name="arch" type="xml">
                <form string="Sinh Viên">
                    <header>
                        <!-- Chỉ hiển thị khi sinh viên chưa được xét điều kiện -->
                        <button name="action_mark_eligible" string="Xác nhận đủ điều kiện" type="object" class="btn-primary" invisible="state != 'new'"/>
                        <!-- Chỉ sinh viên đủ điều kiện và chưa có nguyện vọng mới thấy nút -->
                        <button name="action_register_wish" string="Đăng ký nguyện vọng" type="object" class="btn-primary" invisible="state != 'eligible' or has_thesis_wish"/>
                        <field name="state" widget="statusbar" statusbar_visible="new,eligible,registered,assigned,submitted,defended,graduated"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Thông tin cá nhân">
                                <field name="name"/>
                                <field name="student_code"/>
                                <field name="class_name"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                            <group string="Xét điều kiện làm đồ án">
                                <field name="eligible_date" readonly="1"/>
                                <field name="eligible_checked_by" readonly="1"/>
                                <field name="eligible_note" placeholder="Nhập ghi chú xét điều kiện..."/>
                            </group>
                            <group string="Nguyện vọng làm đồ án">
                                <field name="has_thesis_wish" readonly="1"/>
                                <field name="wish_date" readonly="1"/>
                                <field name="wish_note" placeholder="Nhập ghi chú nguyện vọng..."/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="thesis_student_search" model="ir.ui.view">
            <field name="name">thesis.student.search</field>
            <field name="model">thesis.student</field>
            <field name="arch" type="xml">
                <search string="Tìm Sinh Viên">
                    <field name="name" string="Họ tên"/>
                    <field name="student_code"/>
                    <field name="supervisor_id"/>
                    <separator/>
                    <filter name="eligible" string="Đủ điều kiện" domain="[('state', '=', 'eligible')]"/>
                    <filter name="waiting_eligibility" string="Chưa xét điều kiện" domain="[('state', '=', 'new')]"/>

                    <filter name="has_thesis_wish" string="Có nguyện vọng" domain="[('has_thesis_wish', '=', True)]"/>

                    <filter name="eligible_with_wish" string="Đủ điều kiện và có nguyện vọng" domain="[
            ('state', '=', 'eligible'),
            ('has_thesis_wish', '=', True)
        ]"/>
                    <filter name="registered" string="Đã đăng ký" domain="[('state', '=', 'registered')]"/>
                    <filter name="graduated" string="Tốt nghiệp" domain="[('state', '=', 'graduated')]"/>
                </search>
            </field>
        </record>

        <!-- ACTION -->
        <record id="thesis_student_action" model="ir.actions.act_window">
            <field name="name">Quản Lý Sinh Viên</field>
            <field name="res_model">thesis.student</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- MENU -->
        <menuitem id="menu_thesis_student" name="Quản Lý Sinh Viên" parent="menu_delivery_management" sequence="5" action="thesis_student_action"/>

    </data>
</odoo>