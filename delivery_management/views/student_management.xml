<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="thesis_student_list" model="ir.ui.view">
            <field name="name">thesis.student.list</field>
            <field name="model">thesis.student</field>
            <field name="arch" type="xml">
                <list string="Danh Sách Sinh Viên">
                    <field name="student_code"/>
                    <field name="name"/>
                    <field name="class_name"/>
                    <field name="email"/>
                    <field name="supervisor_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="thesis_student_form" model="ir.ui.view">
            <field name="name">thesis.student.form</field>
            <field name="model">thesis.student</field>
            <field name="arch" type="xml">
                <form string="Sinh Viên">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Thông tin cá nhân">
                                <field name="name"/>
                                <field name="student_code"/>
                                <field name="class_name"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                            <group string="Thông tin đồ án">
                                <field name="thesis_topic_id"/>
                                <field name="supervisor_id"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="thesis_student_search" model="ir.ui.view">
            <field name="name">thesis.student.search</field>
            <field name="model">thesis.student</field>
            <field name="arch" type="xml">
                <search string="Tìm Sinh Viên">
                    <field name="name" string="Họ tên"/>
                    <field name="student_code"/>
                    <field name="supervisor_id"/>
                    <separator/>
                    <filter name="eligible" string="Đủ điều kiện"
                        domain="[('state', '=', 'eligible')]"/>
                    <filter name="registered" string="Đã đăng ký"
                        domain="[('state', '=', 'registered')]"/>
                    <filter name="graduated" string="Tốt nghiệp"
                        domain="[('state', '=', 'graduated')]"/>
                </search>
            </field>
        </record>

        <!-- ACTION -->
        <record id="thesis_student_action" model="ir.actions.act_window">
            <field name="name">Quản Lý Sinh Viên</field>
            <field name="res_model">thesis.student</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- MENU -->
        <menuitem id="menu_thesis_student"
            name="Quản Lý Sinh Viên"
            parent="menu_delivery_management"
            sequence="5"
            action="thesis_student_action"/>

    </data>
</odoo>