<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================================================
             LIST VIEW: Danh sách khoa
             ================================================== -->
        <record id="academic_faculty_list" model="ir.ui.view">
            <field name="name">academic.faculty.list</field>
            <field name="model">academic.faculty</field>
            <field name="arch" type="xml">
                <list string="Danh sách Khoa">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="short_name"/>
                    <field name="dean_id"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- ==================================================
             FORM VIEW: Thông tin chi tiết của khoa
             ================================================== -->
        <record id="academic_faculty_form" model="ir.ui.view">
            <field name="name">academic.faculty.form</field>
            <field name="model">academic.faculty</field>
            <field name="arch" type="xml">
                <form string="Khoa">
                    <sheet>

                        <!-- Tên khoa được hiển thị nổi bật -->
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nhập tên khoa..."/>
                            </h1>
                        </div>

                        <group>
                            <!-- Thông tin nhận diện khoa -->
                            <group string="Thông tin chung">
                                <field name="code"/>
                                <field name="short_name"/>
                                <field name="dean_id"/>
                                <field name="active"/>
                            </group>

                            <!-- Thông tin liên hệ -->
                            <group string="Thông tin liên hệ">
                                <field name="email" widget="email"/>
                                <field name="phone" widget="phone"/>
                                <field name="address"/>
                            </group>
                        </group>

                        <group string="Ghi chú">
                            <field name="note" placeholder="Nhập ghi chú về khoa..."/>
                        </group>

                    </sheet>

                    <!-- Lịch sử thay đổi và hoạt động -->
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ==================================================
             SEARCH VIEW: Tìm kiếm và lọc khoa
             ================================================== -->
        <record id="academic_faculty_search" model="ir.ui.view">
            <field name="name">academic.faculty.search</field>
            <field name="model">academic.faculty</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm Khoa">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="short_name"/>
                    <field name="dean_id"/>

                    <separator/>

                    <filter name="active_faculty" string="Đang hoạt động" domain="[('active', '=', True)]"/>

                    <filter name="inactive_faculty" string="Ngừng hoạt động" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- ==================================================
             ACTION: Mở màn hình quản lý khoa
             ================================================== -->
        <record id="academic_faculty_action" model="ir.actions.act_window">
            <field name="name">Danh mục Khoa</field>
            <field name="res_model">academic.faculty</field>
            <field name="view_mode">list,form</field>

            <!-- Thông báo khi chưa có dữ liệu -->
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo khoa đầu tiên
                </p>
                <p>
                    Quản lý danh sách các khoa trong trường đại học
                </p>
            </field>
        </record>

        <!-- ==================================================
             MENU: Danh mục Khoa
             ================================================== -->
        <menuitem id="menu_academic_faculty" name="Khoa" parent="menu_academic_catalog" action="academic_faculty_action" sequence="1"/>
        <!-- Ẩn menu Khoa con vì menu cha Quản lý Khoa đã mở cùng action -->
        <record id="menu_academic_faculty" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>