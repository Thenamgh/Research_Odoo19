<?xml version="1.0" encoding="utf-8"?>
<!-- views/lecturer_management_view.xml -->
<!-- 08/07/2026 — View quản lý giảng viên hướng dẫn -->
<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="thesis_lecturer_list" model="ir.ui.view">
            <field name="name">thesis.lecturer.list</field>
            <field name="model">thesis.lecturer</field>
            <field name="arch" type="xml">
                <list string="Danh Sách Giảng Viên Hướng Dẫn">
                    <field name="lecturer_code"/>
                    <field name="name"/>

                    <!-- Thông tin chuyên môn-->
                    <field name="academic_rank"/>
                    <field name="academic_degree"/>
                    <field name="specialization" optional="hide"/>

                    <!-- Đơn vị công tác-->
                    <field name="faculty_id"/>
                    <field name="department_id"/>
                    <field name="employment_type"/>

                    <!-- Khả năng hướng dẫn -->
                    <field name="student_count" string="Đang hướng dẫn"/>
                    <field name="max_students" string="Tối đa"/>
                    <field name="available_for_supervision" string="Còn nhận sinh viên"/>
                    <field name="email" optional="hide"/>
                    <field name="phone" optional="hide"/>
                    <field name="active"/>

                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="thesis_lecturer_form" model="ir.ui.view">
            <field name="name">thesis.lecturer.form</field>
            <field name="model">thesis.lecturer</field>
            <field name="arch" type="xml">
                <form string="Giảng Viên Hướng Dẫn">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <!-- Thông tin cá nhân-->
                            <group string="Thông tin cá nhân">
                                <field name="lecturer_code"/>
                                <field name="date_of_birth"/>
                                <field name="gender"/>
                                <field name="email" widget="email"/>
                                <field name="phone" widget="phone"/>
                                <field name="user_id"/>
                            </group>

                            <!-- Thông tin chuyên môn-->
                            <group string="Thông tin chuyên môn">
                                <field name="academic_rank"/>
                                <field name="academic_degree"/>
                                <field name="specialization"/>
                            </group>
                        </group>
                        <group>
                            <!-- Thông tin công tác -->
                            <group string="Thông tin công tác">
                                <field name="faculty_id"/>
                                <field name="department_id" domain="[('faculty_id', '=', faculty_id)]"/>
                                <field name="department" string="Bộ môn cũ" readonly="1" invisible="not department"/>
                                <field name="employment_type"/>
                                <field name="active"/>
                            </group>

                            <!-- Thông tin hướng dẫn -->
                            <group string="Thông tin hướng dẫn đồ án">
                                <field name="student_count" readonly="1"/>
                                <field name="max_students" readonly="1"/>
                                <field name="available_for_supervision" readonly="1"/>
                            </group>
                        </group>

                        <!-- Danh sách SV đang hướng dẫn -->
                        <notebook>
                            <page string="Sinh viên đang hướng dẫn">
                                <field name="student_ids">
                                    <list string="Danh sách sinh viên">
                                        <field name="student_code"/>
                                        <field name="name"/>
                                        <field name="class_name"/>
                                        <field name="thesis_topic_id"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="thesis_lecturer_search" model="ir.ui.view">
            <field name="name">thesis.lecturer.search</field>
            <field name="model">thesis.lecturer</field>
            <field name="arch" type="xml">
                <search string="Tìm Giảng Viên">

                    <!-- Các trường tìm kiếm-->
                    <field name="name" string="Họ tên"/>
                    <field name="lecturer_code"/>
                    <field name="academic_rank"/>
                    <field name="academic_degree"/>
                    <field name="faculty_id"/>
                    <field name="department_id"/>
                    <separator/>
                    <!-- Các bộ lọc -->
                    <filter name="active" string="Đang hoạt động" domain="[('active', '=', True)]"/>
                    <filter name="available" string="Còn nhận sinh viên" domain="[('available_for_supervision', '=', True)]"/>

                    <filter name="full" string="Đã đủ sinh viên" domain="[('active', '=', True), ('available_for_supervision', '=', False)]"/>

                    <separator/>

                    <!-- Nhóm dữ liệu -->
                    <filter name="group_by_degree" string="Theo học vị" context="{'group_by': 'academic_degree'}"/>

                    <filter name="group_by_faculty" string="Theo khoa" context="{'group_by': 'faculty_id'}"/>
                </search>
            </field>
        </record>

        <!-- ACTION -->
        <record id="thesis_lecturer_action" model="ir.actions.act_window">
            <field name="name">Quản Lý Giảng Viên</field>
            <field name="res_model">thesis.lecturer</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- MENU -->
        <menuitem id="menu_thesis_lecturer" name="Quản lý Giảng viên HD" parent="menu_academic_catalog" action="thesis_lecturer_action" sequence="30"/>
    </data>
</odoo>